{
  "name": "job-hunt-vault",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "catalog:sql": "node scripts/company-catalog-csv-to-sql.mjs",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "dev": "vite --host 127.0.0.1",
