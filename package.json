    "react-router-dom": "^7.10.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.16",
    "wrangler": "^4.56.0"
  }
